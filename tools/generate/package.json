{
  "name": "@1stcontact/generate",
  "version": "0.0.1",
  "private": true,
  "description": "Static generator CLI: sites/<name>/ → apps/public-site/public/",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "fc-generate": "./bin/cli.mjs"
  },
  "files": [
    "bin",
    "src",
    "vite.config.mjs"
  ],
  "scripts": {
    "build": "echo 'generate: no build step (vite-node executes TS at runtime)'"
  },
  "dependencies": {
    "@1stcontact/framework": "workspace:*",
    "@1stcontact/site-schema": "workspace:*",
    "astro": "^4.16.0",
    "vite": "^5.0.0",
    "vite-node": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}
