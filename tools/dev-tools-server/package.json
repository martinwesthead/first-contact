{
  "name": "@gendev/dev-tools-server",
  "version": "0.0.1",
  "private": true,
  "description": "Dev-only localhost sidecar that exposes a constrained `xgd ticket` proxy to the builder's chat handler. Never deployed.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./handler": {
      "types": "./src/handler.ts",
      "import": "./src/handler.ts"
    },
    "./spawner": {
      "types": "./src/spawner.ts",
      "import": "./src/spawner.ts"
    }
  },
  "bin": {
    "fc-dev-tools-server": "./bin/start.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "build": "echo 'dev-tools-server: no build step (vite-node executes TS at runtime)'"
  },
  "dependencies": {
    "vite": "^5.0.0",
    "vite-node": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}
