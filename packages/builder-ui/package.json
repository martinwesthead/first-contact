{
  "name": "@1stcontact/builder-ui",
  "version": "0.0.2",
  "private": true,
  "description": "Chat-left / preview-right builder SPA. Served by control-app. (REQ-8)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./catalog": {
      "types": "./src/catalog.ts",
      "import": "./src/catalog.ts"
    },
    "./store": {
      "types": "./src/store.ts",
      "import": "./src/store.ts"
    },
    "./tools": {
      "types": "./src/tools.ts",
      "import": "./src/tools.ts"
    },
    "./preview": {
      "types": "./src/preview.ts",
      "import": "./src/preview.ts"
    },
    "./layout": {
      "types": "./src/components/builder-layout.ts",
      "import": "./src/components/builder-layout.ts"
    },
    "./main": {
      "types": "./src/main.ts",
      "import": "./src/main.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@1stcontact/framework": "workspace:*",
    "@1stcontact/site-schema": "workspace:*",
    "@tiptap/core": "^2.6.0",
    "@tiptap/pm": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "dompurify": "^3.1.6",
    "marked": "^14.1.0",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
