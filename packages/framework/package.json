{
  "name": "@1stcontact/framework",
  "version": "0.0.0",
  "private": true,
  "description": "Section library, renderer, theme tokens — shared between static generator and in-browser builder preview (see DOC-7, DOC-8)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./modules": {
      "types": "./src/modules/index.ts",
      "import": "./src/modules/index.ts"
    },
    "./meta": {
      "types": "./src/modules/meta.ts",
      "import": "./src/modules/meta.ts"
    },
    "./render": {
      "types": "./src/render/index.ts",
      "import": "./src/render/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@1stcontact/site-schema": "workspace:*",
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}
