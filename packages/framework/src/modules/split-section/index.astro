---
import type { AssetRef } from "@gendev/site-schema";

export interface SplitSectionCta {
  label: string;
  href: string;
}

export interface Props {
  variant: "image-left" | "image-right";
  image: AssetRef;
  eyebrow?: string;
  heading: string;
  body: string;
  cta?: SplitSectionCta;
  dials?: {
    size?: "sm" | "md" | "lg";
    spacingTop?: string;
    spacingBottom?: string;
    surface?: "default" | "subtle" | "inverse" | "accent";
    imageRatio?: "square" | "portrait" | "landscape";
  };
}

const {
  variant,
  image,
  eyebrow,
  heading,
  body,
  cta,
  dials = {},
} = Astro.props;

const size = dials.size ?? "md";
const surface = dials.surface ?? "default";
const spacingTop = dials.spacingTop ?? "12";
const spacingBottom = dials.spacingBottom ?? "12";
const imageRatio = dials.imageRatio ?? "landscape";
---

<section
  class:list={[
    "fc-split-section",
    `fc-split-section--variant-${variant}`,
    `fc-split-section--size-${size}`,
    `fc-split-section--surface-${surface}`,
    `fc-split-section--space-top-${spacingTop}`,
    `fc-split-section--space-bottom-${spacingBottom}`,
    `fc-split-section--ratio-${imageRatio}`,
  ]}
  data-module="split-section"
  data-variant={variant}
>
  <div class="fc-split-section__inner">
    <div class="fc-split-section__media" data-fc-split-media>
      <img class="fc-split-section__image" src={image.src} alt={image.alt} />
    </div>
    <div class="fc-split-section__content" data-fc-split-content>
      {eyebrow && <p class="fc-split-section__eyebrow">{eyebrow}</p>}
      <h2 class="fc-split-section__heading">{heading}</h2>
      <div class="fc-split-section__body" set:html={body} />
      {
        cta && (
          <a class="fc-split-section__cta" href={cta.href}>
            {cta.label}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .fc-split-section {
    color: var(--color-text);
    background: var(--color-bg);
  }
  .fc-split-section--surface-subtle { background: var(--color-surface-subtle); }
  .fc-split-section--surface-inverse {
    background: var(--color-surface-inverse);
    color: var(--color-bg);
  }
  .fc-split-section--surface-accent {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .fc-split-section--space-top-0 { padding-top: var(--space-0); }
  .fc-split-section--space-top-1 { padding-top: var(--space-1); }
  .fc-split-section--space-top-2 { padding-top: var(--space-2); }
  .fc-split-section--space-top-3 { padding-top: var(--space-3); }
  .fc-split-section--space-top-4 { padding-top: var(--space-4); }
  .fc-split-section--space-top-6 { padding-top: var(--space-6); }
  .fc-split-section--space-top-8 { padding-top: var(--space-8); }
  .fc-split-section--space-top-12 { padding-top: var(--space-12); }
  .fc-split-section--space-top-16 { padding-top: var(--space-16); }
  .fc-split-section--space-top-24 { padding-top: var(--space-24); }
  .fc-split-section--space-bottom-0 { padding-bottom: var(--space-0); }
  .fc-split-section--space-bottom-1 { padding-bottom: var(--space-1); }
  .fc-split-section--space-bottom-2 { padding-bottom: var(--space-2); }
  .fc-split-section--space-bottom-3 { padding-bottom: var(--space-3); }
  .fc-split-section--space-bottom-4 { padding-bottom: var(--space-4); }
  .fc-split-section--space-bottom-6 { padding-bottom: var(--space-6); }
  .fc-split-section--space-bottom-8 { padding-bottom: var(--space-8); }
  .fc-split-section--space-bottom-12 { padding-bottom: var(--space-12); }
  .fc-split-section--space-bottom-16 { padding-bottom: var(--space-16); }
  .fc-split-section--space-bottom-24 { padding-bottom: var(--space-24); }

  .fc-split-section__inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding-inline: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .fc-split-section__media {
    width: 100%;
  }
  .fc-split-section__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
  .fc-split-section--ratio-square .fc-split-section__media { aspect-ratio: 1 / 1; }
  .fc-split-section--ratio-portrait .fc-split-section__media { aspect-ratio: 3 / 4; }
  .fc-split-section--ratio-landscape .fc-split-section__media { aspect-ratio: 16 / 9; }

  .fc-split-section__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .fc-split-section__eyebrow {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .fc-split-section__heading {
    margin: 0;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
  }
  .fc-split-section--size-sm .fc-split-section__heading { font-size: var(--font-size-2xl); }
  .fc-split-section--size-md .fc-split-section__heading { font-size: var(--font-size-3xl); }
  .fc-split-section--size-lg .fc-split-section__heading { font-size: var(--font-size-4xl); }

  .fc-split-section__body {
    font-family: var(--font-family-body);
    line-height: var(--line-height-relaxed);
    color: inherit;
  }
  .fc-split-section--size-sm .fc-split-section__body { font-size: var(--font-size-base); }
  .fc-split-section--size-md .fc-split-section__body { font-size: var(--font-size-lg); }
  .fc-split-section--size-lg .fc-split-section__body { font-size: var(--font-size-xl); }

  .fc-split-section__body :global(p) { margin: 0 0 var(--space-3); }
  .fc-split-section__body :global(ul),
  .fc-split-section__body :global(ol) {
    margin: 0 0 var(--space-3);
    padding-inline-start: var(--space-6);
  }
  .fc-split-section__body :global(li) { margin-bottom: var(--space-1); }
  .fc-split-section__body :global(a) { color: var(--color-primary); }
  .fc-split-section__body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .fc-split-section__cta {
    display: inline-block;
    align-self: flex-start;
    background: var(--color-primary);
    color: var(--color-bg);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
  }
  .fc-split-section__cta:hover { background: var(--color-accent); }

  @media (min-width: 768px) {
    .fc-split-section__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .fc-split-section--variant-image-right .fc-split-section__media { order: 2; }
    .fc-split-section--variant-image-right .fc-split-section__content { order: 1; }
  }
</style>
