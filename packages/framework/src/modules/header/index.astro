---
import type { AssetRef, NavEntry } from "@gendev/site-schema";
import { hrefForTarget, isAssetRef } from "../shared.js";

export interface Props {
  logo: AssetRef | string;
  entries: NavEntry[];
  dials?: {
    spacingTop?: string;
    spacingBottom?: string;
    surface?: string;
  };
}

const { logo, entries, dials = {} } = Astro.props;
const surface = dials.surface ?? "default";
const spacingTop = dials.spacingTop ?? "4";
const spacingBottom = dials.spacingBottom ?? "4";
---

<header
  class:list={[
    "fc-header",
    `fc-header--surface-${surface}`,
    `fc-header--space-top-${spacingTop}`,
    `fc-header--space-bottom-${spacingBottom}`,
  ]}
  data-module="header"
  data-variant="top-nav"
>
  <div class="fc-header__inner">
    <a class="fc-header__logo" href="/">
      {
        isAssetRef(logo) ? (
          <img src={logo.src} alt={logo.alt} />
        ) : (
          <span class="fc-header__logo-text">{logo}</span>
        )
      }
    </a>

    <button
      class="fc-header__toggle"
      type="button"
      aria-controls="fc-header-nav"
      aria-expanded="false"
      data-fc-header-toggle
    >
      <span class="fc-header__toggle-bar"></span>
      <span class="fc-header__toggle-bar"></span>
      <span class="fc-header__toggle-bar"></span>
      <span class="fc-sr-only">Menu</span>
    </button>

    <nav id="fc-header-nav" class="fc-header__nav" aria-label="Primary">
      <ul class="fc-header__list">
        {
          entries.map((entry) => (
            <li class="fc-header__item">
              <a class="fc-header__link" href={hrefForTarget(entry.target)}>
                {entry.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .fc-header {
    background: var(--color-bg);
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }
  .fc-header--surface-subtle { background: var(--color-surface-subtle); }
  .fc-header--surface-inverse {
    background: var(--color-surface-inverse);
    color: var(--color-bg);
  }
  .fc-header--space-top-0 { padding-top: var(--space-0); }
  .fc-header--space-top-1 { padding-top: var(--space-1); }
  .fc-header--space-top-2 { padding-top: var(--space-2); }
  .fc-header--space-top-3 { padding-top: var(--space-3); }
  .fc-header--space-top-4 { padding-top: var(--space-4); }
  .fc-header--space-top-6 { padding-top: var(--space-6); }
  .fc-header--space-top-8 { padding-top: var(--space-8); }
  .fc-header--space-bottom-0 { padding-bottom: var(--space-0); }
  .fc-header--space-bottom-1 { padding-bottom: var(--space-1); }
  .fc-header--space-bottom-2 { padding-bottom: var(--space-2); }
  .fc-header--space-bottom-3 { padding-bottom: var(--space-3); }
  .fc-header--space-bottom-4 { padding-bottom: var(--space-4); }
  .fc-header--space-bottom-6 { padding-bottom: var(--space-6); }
  .fc-header--space-bottom-8 { padding-bottom: var(--space-8); }

  .fc-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-default);
    margin: 0 auto;
    padding-inline: var(--space-4);
    gap: var(--space-4);
  }

  .fc-header__logo {
    color: inherit;
    text-decoration: none;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-tight);
  }
  .fc-header__logo img { display: block; max-height: 2rem; width: auto; }

  .fc-header__nav { display: none; }
  .fc-header__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-4);
  }
  .fc-header__link {
    color: inherit;
    text-decoration: none;
    font-family: var(--font-family-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-normal);
  }
  .fc-header__link:hover { color: var(--color-primary); }

  .fc-header__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    padding: 0.4rem;
  }
  .fc-header__toggle-bar {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
  }
  .fc-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .fc-header__nav { display: block; }
    .fc-header__toggle { display: none; }
  }

  .fc-header[data-fc-open="true"] .fc-header__nav {
    display: block;
    width: 100%;
    flex-basis: 100%;
  }
  .fc-header[data-fc-open="true"] .fc-header__list {
    flex-direction: column;
    align-items: flex-start;
  }
</style>
