---
import type { AssetRef, NavEntry } from "@gendev/site-schema";
import { hrefForTarget, isAssetRef } from "../shared.js";

export interface Props {
  logo?: AssetRef | string;
  tagline?: string;
  copyrightHolder: string;
  copyrightYear: string;
  links?: NavEntry[];
  dials?: {
    spacingTop?: string;
    spacingBottom?: string;
    surface?: string;
  };
}

const {
  logo,
  tagline,
  copyrightHolder,
  copyrightYear,
  links,
  dials = {},
} = Astro.props;

const surface = dials.surface ?? "subtle";
const spacingTop = dials.spacingTop ?? "8";
const spacingBottom = dials.spacingBottom ?? "8";
---

<footer
  class:list={[
    "fc-footer",
    `fc-footer--surface-${surface}`,
    `fc-footer--space-top-${spacingTop}`,
    `fc-footer--space-bottom-${spacingBottom}`,
  ]}
  data-module="footer"
  data-variant="minimal"
>
  <div class="fc-footer__inner">
    {
      logo && (
        <div class="fc-footer__logo">
          {isAssetRef(logo) ? (
            <img src={logo.src} alt={logo.alt} />
          ) : (
            <span>{logo}</span>
          )}
        </div>
      )
    }
    {tagline && <p class="fc-footer__tagline">{tagline}</p>}
    {
      links && links.length > 0 && (
        <nav class="fc-footer__nav" aria-label="Footer">
          <ul class="fc-footer__list">
            {links.map((entry) => (
              <li class="fc-footer__item">
                <a class="fc-footer__link" href={hrefForTarget(entry.target)}>
                  {entry.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
    <p class="fc-footer__copyright">
      &copy; {copyrightYear} {copyrightHolder}
    </p>
  </div>
</footer>

<style>
  .fc-footer {
    background: var(--color-surface);
    color: var(--color-text);
    border-top: 1px solid var(--color-border);
  }
  .fc-footer--surface-subtle { background: var(--color-surface-subtle); }
  .fc-footer--surface-inverse {
    background: var(--color-surface-inverse);
    color: var(--color-bg);
  }
  .fc-footer--space-top-0 { padding-top: var(--space-0); }
  .fc-footer--space-top-1 { padding-top: var(--space-1); }
  .fc-footer--space-top-2 { padding-top: var(--space-2); }
  .fc-footer--space-top-3 { padding-top: var(--space-3); }
  .fc-footer--space-top-4 { padding-top: var(--space-4); }
  .fc-footer--space-top-6 { padding-top: var(--space-6); }
  .fc-footer--space-top-8 { padding-top: var(--space-8); }
  .fc-footer--space-bottom-0 { padding-bottom: var(--space-0); }
  .fc-footer--space-bottom-1 { padding-bottom: var(--space-1); }
  .fc-footer--space-bottom-2 { padding-bottom: var(--space-2); }
  .fc-footer--space-bottom-3 { padding-bottom: var(--space-3); }
  .fc-footer--space-bottom-4 { padding-bottom: var(--space-4); }
  .fc-footer--space-bottom-6 { padding-bottom: var(--space-6); }
  .fc-footer--space-bottom-8 { padding-bottom: var(--space-8); }

  .fc-footer__inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding-inline: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
    font-family: var(--font-family-body);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
    color: var(--color-muted);
  }
  .fc-footer__logo img { display: block; max-height: 1.5rem; }
  .fc-footer__tagline { margin: 0; }
  .fc-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .fc-footer__link {
    color: inherit;
    text-decoration: none;
  }
  .fc-footer__link:hover { color: var(--color-primary); }
  .fc-footer__copyright { margin: 0; }
</style>
