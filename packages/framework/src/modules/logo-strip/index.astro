---
import type { AssetRef } from "@gendev/site-schema";

export interface LogoStripItem {
  image: AssetRef;
  label?: string;
  href?: string;
}

export interface Props {
  variant: "logos" | "features";
  heading?: string;
  items: LogoStripItem[];
  dials?: {
    columns?: "3" | "4" | "5" | "6";
    spacingTop?: string;
    spacingBottom?: string;
    surface?: "default" | "subtle" | "inverse";
  };
}

const { variant, heading, items, dials = {} } = Astro.props;
const columns = dials.columns ?? "4";
const surface = dials.surface ?? "default";
const spacingTop = dials.spacingTop ?? "12";
const spacingBottom = dials.spacingBottom ?? "12";

function isExternal(href: string): boolean {
  return /^(https?:)?\/\//.test(href);
}
---

<section
  class:list={[
    "fc-logo-strip",
    `fc-logo-strip--variant-${variant}`,
    `fc-logo-strip--columns-${columns}`,
    `fc-logo-strip--surface-${surface}`,
    `fc-logo-strip--space-top-${spacingTop}`,
    `fc-logo-strip--space-bottom-${spacingBottom}`,
  ]}
  data-module="logo-strip"
  data-variant={variant}
>
  <div class="fc-logo-strip__inner">
    {heading && <h2 class="fc-logo-strip__heading">{heading}</h2>}
    <ul class="fc-logo-strip__list" role="list">
      {
        items.map((item) => {
          const altText = item.label ?? item.image.alt;
          const showLabel = variant === "features" && item.label;
          const inner = (
            <>
              <div class="fc-logo-strip__media">
                <img
                  class="fc-logo-strip__image"
                  src={item.image.src}
                  alt={altText}
                  loading="lazy"
                />
              </div>
              {showLabel && (
                <span class="fc-logo-strip__label">{item.label}</span>
              )}
            </>
          );
          return (
            <li class="fc-logo-strip__item">
              {item.href ? (
                <a
                  class="fc-logo-strip__link"
                  href={item.href}
                  target={isExternal(item.href) ? "_blank" : undefined}
                  rel={isExternal(item.href) ? "noopener noreferrer" : undefined}
                >
                  {inner}
                </a>
              ) : (
                <div class="fc-logo-strip__link fc-logo-strip__link--static">
                  {inner}
                </div>
              )}
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .fc-logo-strip {
    color: var(--color-text);
    background: var(--color-bg);
  }
  .fc-logo-strip--surface-subtle { background: var(--color-surface-subtle); }
  .fc-logo-strip--surface-inverse {
    background: var(--color-surface-inverse);
    color: var(--color-bg);
  }

  .fc-logo-strip--space-top-0 { padding-top: var(--space-0); }
  .fc-logo-strip--space-top-1 { padding-top: var(--space-1); }
  .fc-logo-strip--space-top-2 { padding-top: var(--space-2); }
  .fc-logo-strip--space-top-3 { padding-top: var(--space-3); }
  .fc-logo-strip--space-top-4 { padding-top: var(--space-4); }
  .fc-logo-strip--space-top-6 { padding-top: var(--space-6); }
  .fc-logo-strip--space-top-8 { padding-top: var(--space-8); }
  .fc-logo-strip--space-top-12 { padding-top: var(--space-12); }
  .fc-logo-strip--space-top-16 { padding-top: var(--space-16); }
  .fc-logo-strip--space-top-24 { padding-top: var(--space-24); }
  .fc-logo-strip--space-bottom-0 { padding-bottom: var(--space-0); }
  .fc-logo-strip--space-bottom-1 { padding-bottom: var(--space-1); }
  .fc-logo-strip--space-bottom-2 { padding-bottom: var(--space-2); }
  .fc-logo-strip--space-bottom-3 { padding-bottom: var(--space-3); }
  .fc-logo-strip--space-bottom-4 { padding-bottom: var(--space-4); }
  .fc-logo-strip--space-bottom-6 { padding-bottom: var(--space-6); }
  .fc-logo-strip--space-bottom-8 { padding-bottom: var(--space-8); }
  .fc-logo-strip--space-bottom-12 { padding-bottom: var(--space-12); }
  .fc-logo-strip--space-bottom-16 { padding-bottom: var(--space-16); }
  .fc-logo-strip--space-bottom-24 { padding-bottom: var(--space-24); }

  .fc-logo-strip__inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding-inline: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .fc-logo-strip__heading {
    margin: 0;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-3xl);
    line-height: var(--line-height-tight);
    text-align: center;
  }

  .fc-logo-strip__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    align-items: center;
    justify-items: center;
  }

  /* Mobile defaults: logos = 2 cols, features = 1 col */
  .fc-logo-strip--variant-logos .fc-logo-strip__list {
    grid-template-columns: repeat(2, 1fr);
  }
  .fc-logo-strip--variant-features .fc-logo-strip__list {
    grid-template-columns: 1fr;
  }

  /* Tablet: half the desktop count, rounded up */
  @media (min-width: 768px) {
    .fc-logo-strip--columns-3 .fc-logo-strip__list,
    .fc-logo-strip--columns-4 .fc-logo-strip__list {
      grid-template-columns: repeat(2, 1fr);
    }
    .fc-logo-strip--columns-5 .fc-logo-strip__list,
    .fc-logo-strip--columns-6 .fc-logo-strip__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Desktop: as configured */
  @media (min-width: 1024px) {
    .fc-logo-strip--columns-3 .fc-logo-strip__list {
      grid-template-columns: repeat(3, 1fr);
    }
    .fc-logo-strip--columns-4 .fc-logo-strip__list {
      grid-template-columns: repeat(4, 1fr);
    }
    .fc-logo-strip--columns-5 .fc-logo-strip__list {
      grid-template-columns: repeat(5, 1fr);
    }
    .fc-logo-strip--columns-6 .fc-logo-strip__list {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .fc-logo-strip__item { margin: 0; width: 100%; }

  .fc-logo-strip__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: inherit;
    text-decoration: none;
    width: 100%;
  }
  a.fc-logo-strip__link:hover .fc-logo-strip__image {
    opacity: 1;
  }

  .fc-logo-strip__media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .fc-logo-strip__image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* Logos variant: larger image, no label visible */
  .fc-logo-strip--variant-logos .fc-logo-strip__image {
    max-height: 64px;
    opacity: 0.75;
    transition: opacity 0.2s ease;
  }
  .fc-logo-strip--variant-logos a.fc-logo-strip__link:hover .fc-logo-strip__image {
    opacity: 1;
  }

  /* Features variant: smaller icon with label beneath */
  .fc-logo-strip--variant-features .fc-logo-strip__image {
    max-height: 40px;
  }
  .fc-logo-strip__label {
    font-family: var(--font-family-body);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    text-align: center;
  }
</style>
