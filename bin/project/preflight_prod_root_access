#!/usr/bin/env python3
"""Preflight check for production root access patterns (stub).

This is a stub generated by ``xgd init``. It always passes.

This check is specific to the xgd platform itself. It scans xgd_source/
for unguarded direct reads of os.environ["XGD_PROJECT_ROOT"] that bypass
the test-isolation guard in xgd_source.core.project_root.get_project_root.

For projects that are not the xgd platform, this check is irrelevant and
the stub is the correct final state — leave it as-is.

Output schema (JSON to stdout):
  {
    "preflight": {
      "status": "pass" | "fail",
      "violations": [...]
    }
  }

Exit codes: 0 = pass, 1 = violations found, 2 = internal error.
"""

from __future__ import annotations

import json
import sys


def main() -> int:
    report = {"preflight": {"status": "pass", "violations": []}}
    sys.stdout.write(json.dumps(report))
    return 0


if __name__ == "__main__":
    sys.exit(main())
