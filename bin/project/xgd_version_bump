#!/usr/bin/env python3
"""Project version-bump script for 1stcontact.

Bumps the monorepo version anchor — the root ``package.json`` ``version``
field — so every free-coded commit carries a distinct version. This protects
the merge-version-max driver and gives the free-coding gate
(``xgd ticket move-to-free-coded``) a concrete bump to verify.

Interface:

  ./bin/project/xgd_version_bump                       # patch bump (default)
  ./bin/project/xgd_version_bump --minor               # minor bump (resets patch)
  ./bin/project/xgd_version_bump --major               # major bump (resets minor+patch)
  ./bin/project/xgd_version_bump --list-paths          # files this script writes
  ./bin/project/xgd_version_bump --check <sha>... --version X.Y.Z
                                                       # gate: verify the bump
  ./bin/project/xgd_version_bump --help                # usage

``--list-paths`` exits 0 and prints one repo-relative path per line.
``--check`` exits 0 iff the given version matches the current root
package.json AND that version line was introduced by one of the commits.
"""

from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path

# The monorepo version anchor. Dep-discovery excludes these from the
# file-overlap signal so a version-only churn line is not a false dependency.
WRITTEN_PATHS: list[str] = ["package.json"]

_REPO_ROOT = Path(__file__).resolve().parents[2]
_PKG_JSON = _REPO_ROOT / "package.json"
_VERSION_RE = re.compile(r"^\d+\.\d+\.\d+$")


def _read_version() -> tuple[int, int, int]:
    data = json.loads(_PKG_JSON.read_text(encoding="utf-8"))
    raw = str(data.get("version", ""))
    if not _VERSION_RE.match(raw):
        raise SystemExit(f"package.json version {raw!r} is not X.Y.Z")
    major, minor, patch = (int(p) for p in raw.split("."))
    return major, minor, patch


def _write_version(version: str) -> None:
    # Preserve formatting: rewrite only the version line so the diff stays
    # to a single line (clean merge-version-max resolution).
    text = _PKG_JSON.read_text(encoding="utf-8")
    new_text, n = re.subn(
        r'("version"\s*:\s*")\d+\.\d+\.\d+(")',
        rf"\g<1>{version}\g<2>",
        text,
        count=1,
    )
    if n != 1:
        raise SystemExit("could not locate a version field in package.json")
    _PKG_JSON.write_text(new_text, encoding="utf-8")


def _bump(level: str) -> int:
    major, minor, patch = _read_version()
    old = f"{major}.{minor}.{patch}"
    if level == "major":
        major, minor, patch = major + 1, 0, 0
    elif level == "minor":
        minor, patch = minor + 1, 0
    else:
        patch += 1
    new = f"{major}.{minor}.{patch}"
    _write_version(new)
    print(f"{old} -> {new}  ({level})")
    return 0


def _check(shas: list[str], version: str) -> int:
    if not _VERSION_RE.match(version):
        print(f"invalid --version {version!r}", file=sys.stderr)
        return 1
    # The version must match the current (committed) package.json.
    major, minor, patch = _read_version()
    if f"{major}.{minor}.{patch}" != version:
        print(
            f"package.json version {major}.{minor}.{patch} != claimed {version}",
            file=sys.stderr,
        )
        return 1
    # ...and that line must have been introduced by one of the commits.
    needle = f'"version": "{version}"'
    for sha in shas:
        # `git show <sha>` scoped to package.json; added lines start with '+'.
        diff = subprocess.run(
            ["git", "show", sha, "--", "package.json"],
            cwd=str(_REPO_ROOT),
            capture_output=True,
            text=True,
        )
        if diff.returncode != 0:
            continue
        for line in diff.stdout.splitlines():
            if line.startswith("+") and needle in line:
                return 0
    print(
        f"version {version} not introduced by any of: {', '.join(shas)}",
        file=sys.stderr,
    )
    return 1


def main(argv: list[str]) -> int:
    if argv and argv[0] in ("--help", "-h"):
        print(__doc__)
        return 0
    if argv and argv[0] == "--list-paths":
        for p in WRITTEN_PATHS:
            print(p)
        return 0
    if argv and argv[0] == "--check":
        rest = argv[1:]
        if "--version" not in rest:
            print("--check requires --version X.Y.Z", file=sys.stderr)
            return 1
        vi = rest.index("--version")
        shas = rest[:vi]
        version = rest[vi + 1] if vi + 1 < len(rest) else ""
        return _check(shas, version)
    if argv and argv[0] == "--minor":
        return _bump("minor")
    if argv and argv[0] == "--major":
        return _bump("major")
    return _bump("patch")


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
