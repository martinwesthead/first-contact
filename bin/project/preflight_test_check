"""Preflight check for test isolation violations (stub).

This is a stub generated by ``xgd init``. Replace with a real implementation
if your project needs test isolation enforcement.

The xgd project itself has a full implementation that scans test files for
patterns that escape ``tmp_path`` isolation (Path.home(), direct os.environ
mutations, hardcoded /Users/ paths). See bin/project/preflight_test_check
in the xgd source repo for the reference implementation.

Required interface:

  ./bin/project/preflight_test_check <file> [<file>...]  # scope to files
  ./bin/project/preflight_test_check --all               # walk full tests/

Output schema (JSON to stdout):
  {
    "preflight": {
      "status": "pass" | "fail",
      "violations": [
        {
          "file":           "tests/...",
          "line":           42,
          "rule":           "<rule-name>",
          "message":        "<what's wrong>",
          "suggested_fix":  "<concrete step>"
        }
      ]
    }
  }

Exit codes: 0 = pass, 1 = violations found, 2 = internal error.

Scope contract: the caller (QualityRunner) always passes either one or more
test file paths as positional arguments, or --all for a whole-tree walk.
Invocation with no arguments is a configuration error — exit 2.
"""

from __future__ import annotations

import json
import sys


def main(argv: list[str]) -> int:
    if not argv:
        report = {
            "preflight": {
                "status": "fail",
                "violations": [{
                    "file": "<runner>",
                    "line": 0,
                    "rule": "preflight_runner",
                    "message": (
                        "preflight_test_check invoked without scope. "
                        "Pass one or more test file paths, or --all."
                    ),
                    "suggested_fix": (
                        "Caller must pass scope explicitly. This is a "
                        "configuration error in the runner, not the tests."
                    ),
                }],
            }
        }
        sys.stdout.write(json.dumps(report))
        sys.stderr.write(
            "preflight_test_check: scope required (--all or file paths)\n"
        )
        return 2

    # Stub: always passes. Replace with real AST-based checks if needed.
    report = {"preflight": {"status": "pass", "violations": []}}
    sys.stdout.write(json.dumps(report))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
