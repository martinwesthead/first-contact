{
  "name": "@1stcontact/control-app",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "build:bundle": "node scripts/build-builder-bundle.mjs",
    "build": "pnpm build:bundle && tsc --noEmit",
    "deploy": "pnpm build:bundle && wrangler deploy",
    "dryrun": "pnpm build:bundle && wrangler deploy --dry-run --outdir=.wrangler/dryrun"
  },
  "dependencies": {
    "@1stcontact/builder-ui": "workspace:*",
    "@1stcontact/extractor": "workspace:*",
    "@1stcontact/web-fetch-safety": "workspace:*",
    "@cloudflare/puppeteer": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "wrangler": "^3.80.0"
  }
}
