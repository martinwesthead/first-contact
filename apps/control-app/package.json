{
  "name": "@gendev/control-app",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n bundle,wrangler,sidecar -c yellow,magenta,cyan \"pnpm build:bundle:watch\" \"wrangler dev --port 8788\" \"node ../../tools/dev-tools-server/bin/start.mjs\"",
    "build:bundle": "node scripts/build-builder-bundle.mjs",
    "build:bundle:watch": "node scripts/build-builder-bundle.mjs --watch",
    "build": "pnpm build:bundle && tsc --noEmit",
    "deploy": "pnpm build:bundle && wrangler deploy",
    "dryrun": "pnpm build:bundle && wrangler deploy --dry-run --outdir=.wrangler/dryrun"
  },
  "dependencies": {
    "@gendev/builder-ui": "workspace:*",
    "@gendev/extractor": "workspace:*",
    "@gendev/framework": "workspace:*",
    "@gendev/site-schema": "workspace:*",
    "@gendev/web-fetch-safety": "workspace:*",
    "@cloudflare/puppeteer": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "wrangler": "^4.103.0"
  }
}
